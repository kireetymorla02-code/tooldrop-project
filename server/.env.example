PORT=5001
DATABASE_URL=postgresql://tooldrop:tooldrop@localhost:5432/tooldrop
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# Optional: comma-separated phones/emails allowed elevated roles in production
ROLE_ALLOWLIST=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: Email OTP via SMTP when unset, OTP is logged in dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ToolDrop <noreply@tooldrop.app>
